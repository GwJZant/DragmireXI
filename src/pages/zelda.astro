		description: 'Textured dumped using Citra.',
		folderUrl: 'https://drive.google.com/drive/folders/1o3h9X_f2v4LOkG3l8e3Ln_exfVPW-MOp?usp=drive_link',
	},
	{
		label: 'The Legend of Zelda: Skyward Sword',
		description: 'Textures dumped using Dolphin.',
