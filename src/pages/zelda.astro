		description: 'Textures dumped using Cemu. I played the entire game so this is likely complete.',
		folderUrl: 'https://drive.google.com/drive/folders/1ushaDI5gM_aZW6WCl0BoP0ogM_qljKFm?usp=drive_link',
	},
	{
		label: 'The Legend of Zelda: Twilight Princess',
		description: 'Textures dumped using Dolphin. I played the entire game so this is likely complete.',
		folderUrl: 'https://drive.google.com/drive/folders/1xhj7Onm3VD_mZR9wJ6B_fxrdqMQXbk6Y?usp=drive_link',
	},
	{
		label: 'The Legend of Zelda: Wind Waker HD',
		description: 'Textures dumped using Cemu.',
		folderUrl: 'https://drive.google.com/drive/folders/1YvTfnQBcAVtQpqkZMOSddj8XmdIubELN?usp=drive_link',
	},
	{
		label: 'The Legend of Zelda: Wind Waker',
		description: 'Textures dumped using Dolphin.',
		folderUrl: 'https://drive.google.com/drive/folders/1IBYRbElOZsFR7Sj1aFzAPHmakOMEDLMZ?usp=drive_link',
	},
	{
		label: 'The Legend of Zelda: Majora\'s Mask 3D',
