		description: 'I forget which emulator I used for this one. I loaded a complete save file and explored so this one may be more incomplete than the others.',
		folderUrl: 'https://drive.google.com/drive/folders/1ztpgGXfa6tK9RbAOdzE1Ya89d7NZiVnY?usp=drive_link',
	},
	{
		label: 'The Legend of Zelda: A Link Between Worlds',
		description: 'Textured dumped using Citra.',
		folderUrl: 'https://drive.google.com/drive/folders/1gYdc6FCntzRD3UcFoxCPi6uHJKo7q4qx?usp=drive_link',
	},
	{
