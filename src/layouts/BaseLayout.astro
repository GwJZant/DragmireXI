---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import packageJson from '../../package.json';

interface Props {
	title: string;
	wide?: boolean;
}

const { title, wide = false } = Astro.props;
const appVersion = packageJson.version;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <script is:inline>
        try {
            if (localStorage.getItem('dragmirexi-theme') === 'link') {
                document.documentElement.setAttribute('data-theme', 'link');
            }
        } catch (_) {}
    </script>
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Cinzel:wght@700&display=swap" rel="stylesheet">
    <title>{title}</title>
    <style is:global>
        html,
        body {
            margin: 0;
        }

        /*
         * Sticky footer: html has a definite height so body’s min-height:100% fills the viewport
         * when content is short; main flex-grow absorbs the gap. Body may still grow taller than
         * the viewport when content is long (no footer overlap).
         */
        html {
            height: 100%;
        }
        h1, h2, .site-nav a {
            font-family: 'Cinzel', serif; /* Sharp, epic look for the titles */
            text-transform: uppercase;
        }
        h1, h2 {
            letter-spacing: 0.15em;
        }
        body {
            min-height: 100%;
            display: flex;
            flex-direction: column;
            background: var(--bg-dark); 
            color: var(--body-text);
            font-family: 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.6;
            transition: background-color 0.25s ease, color 0.25s ease;
        }
        main {
            flex: 1 0 auto;
        }
        .yt-button {
            display: inline-block;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            background: var(--power-gold);
            color: black; /* Better contrast on gold */
            transition: transform 0.2s;
        }
        .yt-button:hover {
            background: var(--ganon-red);
            transform: scale(1.05);
            color: white;
        }        
        .site-nav {
            display: flex;
            flex-shrink: 0;
            align-items: center;
            justify-content: flex-end;
            padding: 1.5rem 2rem;
            background: var(--nav-bg);
            transition: background-color 0.25s ease;
        }
        .site-nav__top {
            display: contents;
        }
        .site-nav__menu {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: flex-end;
            gap: 2rem;
        }
        .site-nav a {
            color: var(--nav-link);
            text-decoration: none;
            font-weight: bold;
            transition: color 0.3s, text-shadow 0.3s;
        }
        .site-nav a:hover {
            color: var(--power-gold);
            text-shadow: 0 0 8px var(--ganon-red);
        }
        .site-nav__menu-btn {
            display: none;
            position: relative;
            align-items: center;
            justify-content: center;
            width: 2.75rem;
            height: 2.75rem;
            padding: 0;
            border: none;
            background: transparent;
            color: var(--nav-link);
            cursor: pointer;
            border-radius: 6px;
            flex-shrink: 0;
        }
        .site-nav__menu-btn:hover {
            color: var(--power-gold);
        }
        .site-nav__menu-btn:focus {
            outline: none;
        }
        .site-nav__menu-btn:focus-visible {
            outline: 2px solid var(--power-gold);
            outline-offset: 2px;
        }
        .site-nav__menu-btn-text {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }
        .site-nav__bars {
            display: flex;
            flex-direction: column;
            gap: 5px;
            width: 1.35rem;
        }
        .site-nav__bars span {
            display: block;
            height: 2px;
            background: currentColor;
            border-radius: 1px;
            transition: transform 0.2s ease, opacity 0.2s ease;
        }
        .site-nav.is-open .site-nav__bars span:nth-child(1) {
            transform: translateY(7px) rotate(45deg);
        }
        .site-nav.is-open .site-nav__bars span:nth-child(2) {
            opacity: 0;
        }
        .site-nav.is-open .site-nav__bars span:nth-child(3) {
            transform: translateY(-7px) rotate(-45deg);
        }
        @media (max-width: 768px) {
            .site-nav {
                flex-direction: column;
                align-items: stretch;
                padding: 1rem 1.25rem;
            }
            .site-nav__top {
                display: flex;
                justify-content: flex-end;
            }
            .site-nav__menu-btn {
                display: inline-flex;
            }
            .site-nav__menu {
                display: none;
                flex-direction: column;
                align-items: stretch;
                flex-wrap: nowrap;
                gap: 0;
                margin-top: 0.75rem;
                padding: 0.35rem 0 0.65rem;
                background: var(--bg-dark);
                border-top: 1px solid var(--border-subtle);
                border-bottom: 1px solid var(--border-subtle);
            }
            .site-nav.is-open .site-nav__menu {
                display: flex;
            }
            .site-nav__menu a {
                padding: 0.85rem 1.25rem;
                text-align: center;
            }
            .site-nav__menu a:hover,
            .site-nav__menu a:focus-visible {
                background: var(--card-bg);
            }
        }
        footer {
            flex-shrink: 0;
            margin-top: 4rem;
            padding: 3rem 0;
            background: var(--footer-bg);
            border-top: 1px solid var(--ganon-red);
            color: var(--footer-text);
            font-size: 0.9rem;
            text-align: center;
            transition: background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease;
        }

        .footer-theme-toggle {
            background: none;
            border: none;
            font: inherit;
            color: inherit;
            cursor: pointer;
            padding: 0.2rem 0.45rem;
            border-radius: 4px;
        }

        .footer-theme-toggle:hover {
            color: var(--power-gold);
            text-decoration: underline;
        }

        .footer-theme-toggle:focus {
            outline: none;
        }

        .footer-theme-toggle:focus-visible {
            outline: 2px solid var(--power-gold);
            outline-offset: 2px;
        }

        .footer-links {
            margin-top: 1rem;
            display: flex;
            justify-content: center;
            gap: 1.5rem;
        }

        .footer-links a {
            color: var(--footer-text);
            text-decoration: none;
        }

        .footer-links a svg {
            width: 28px;  /* Adjust size as needed */
            height: 28px;
            transition: transform 0.2s, fill 0.2s;
        }

        .footer-links a:hover svg {
            fill: #FF0000; /* Classic YouTube Red */
            transform: scale(1.1);
        }

        /* Add this to your existing footer styles */
        .footer-links a[aria-label="GitHub"]:hover svg {
            fill: #ffffff; /* GitHub White/Silver */
            filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.4));
            transform: scale(1.1);
        }

        .footer-version {
            margin-top: 1rem;
            font-size: 0.82rem;
            color: var(--footer-text);
            opacity: 0.92;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
            text-align: center;
            box-sizing: border-box;
        }

        main.container.container--wide {
            max-width: min(1200px, 100%);
            width: 100%;
            display: flex;
            flex-direction: column;
        }
    </style>
</head>
<body>
    <nav class="site-nav" aria-label="Main navigation">
        <div class="site-nav__top">
            <button
                type="button"
                class="site-nav__menu-btn"
                id="site-nav-toggle"
                aria-expanded="false"
                aria-controls="site-nav-menu"
            >
                <span class="site-nav__menu-btn-text">Menu</span>
                <span class="site-nav__bars" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                </span>
            </button>
        </div>
        <div class="site-nav__menu" id="site-nav-menu">
            <a href="/">Home</a>
            <a href="/zelda">Zelda</a>
            <a href="/timeline">Timeline Lab</a>
            <a href="/blog">Theory Blog</a>
            <a href="/about">About</a>
        </div>
    </nav>
    <main class:list={['container', { 'container--wide': wide }]}>
        <slot /> 
    </main>
    <footer>
        <div class="footer-content">
            <p>
                <button
                    type="button"
                    class="footer-theme-toggle"
                    id="theme-toggle"
                    aria-label="Toggle color theme"
                    title="Toggle color theme (classic / Link-inspired)"
                >
                    &copy; {new Date().getFullYear()} DragmireXI
                </button>
            </p>
            <div class="footer-links">
                <a href="https://www.youtube.com/@DragmireXI" aria-label="YouTube">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                </a>
                <a href="https://github.com/GwJZant" aria-label="GitHub">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                </a>
            </div>
            <p class="footer-version">{appVersion}</p>
        </div>
    </footer>
    <script is:inline>
        (function () {
            var KEY = 'dragmirexi-theme';
            var root = document.documentElement;
            var btn = document.getElementById('theme-toggle');
            function apply(theme) {
                if (theme === 'link') root.setAttribute('data-theme', 'link');
                else root.removeAttribute('data-theme');
            }
            btn &&
                btn.addEventListener('click', function () {
                    var next = root.getAttribute('data-theme') === 'link' ? 'ganon' : 'link';
                    apply(next);
                    try {
                        localStorage.setItem(KEY, next);
                    } catch (_) {}
                });
        })();
    </script>
    <script is:inline>
        (function () {
            var nav = document.querySelector('.site-nav');
            if (!nav) return;
            var toggle = document.getElementById('site-nav-toggle');
            var menu = document.getElementById('site-nav-menu');
            if (!toggle || !menu) return;
            function setOpen(open) {
                nav.classList.toggle('is-open', open);
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            }
            toggle.addEventListener('click', function (e) {
                e.stopPropagation();
                setOpen(!nav.classList.contains('is-open'));
            });
            menu.querySelectorAll('a').forEach(function (link) {
                link.addEventListener('click', function () {
                    setOpen(false);
                });
            });
            document.addEventListener('click', function () {
                setOpen(false);
            });
            nav.addEventListener('click', function (e) {
                e.stopPropagation();
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') setOpen(false);
            });
        })();
    </script>
</body>
</html>