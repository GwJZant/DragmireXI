---
// src/layouts/BaseLayout.astro
import '../styles/global.css';

const { title } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Cinzel:wght@700&display=swap" rel="stylesheet">
    <title>{title}</title>
    <style is:global>
        html, body {
            height: 100%;
            margin: 0;
        }
        h1, h2, nav a {
            font-family: 'Cinzel', serif; /* Sharp, epic look for the titles */
            text-transform: uppercase;
        }
        h1, h2 {
            letter-spacing: 0.15em;
        }
        body { 
            display: flex;
            flex-direction: column;
            background: var(--bg-dark); 
            color: #e0e0e0; /* Off-white for better readability against black */
            font-family: 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.6;
        }
        main {
            flex: 1;
        }
        .yt-button {
            display: inline-block;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            background: var(--power-gold);
            color: black; /* Better contrast on gold */
            transition: transform 0.2s;
        }
        .yt-button:hover {
            background: var(--ganon-red);
            transform: scale(1.05);
            color: white;
        }        
        nav { 
            display: flex; 
            justify-content: flex-end; 
            padding: 1.5rem 2rem; 
            gap: 2rem;
            background: rgba(0,0,0,0.3);
        }
        nav a { 
            color: white; 
            text-decoration: none; 
            font-weight: bold; 
            transition: color 0.3s, text-shadow 0.3s;
        }
        nav a:hover { 
            color: var(--power-gold);
            text-shadow: 0 0 8px var(--ganon-red);
        }
        footer {
            flex-shrink: 0;
            margin-top: 4rem;
            padding: 3rem 0;
            background: rgba(0, 0, 0, 0.5); /* Semi-transparent black */
            border-top: 1px solid var(--ganon-red);
            color: #888;
            font-size: 0.9rem;
            text-align: center;
        }

        .footer-links {
            margin-top: 1rem;
            display: flex;
            justify-content: center;
            gap: 1.5rem;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .footer-links a {
            color: #888; /* Or whatever your 'dim' color is */
        }

        .footer-links a svg {
            width: 28px;  /* Adjust size as needed */
            height: 28px;
            transition: transform 0.2s, fill 0.2s;
        }

        .footer-links a:hover svg {
            fill: #FF0000; /* Classic YouTube Red */
            transform: scale(1.1);
        }

        /* Add this to your existing footer styles */
        .footer-links a[aria-label="GitHub"]:hover svg {
            fill: #ffffff; /* GitHub White/Silver */
            filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.4));
            transform: scale(1.1);
        }

        .container { max-width: 800px; margin: 0 auto; padding: 2rem; text-align: center; }
    </style>
</head>
<body>
    <nav aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/blog">Blog</a>
    </nav>
    <main class="container">
        <slot /> 
    </main>
    <footer>
        <div class="footer-content">
            <p>&copy; {new Date().getFullYear()} DragmireXI</p>
            <div class="footer-links">
                <a href="https://www.youtube.com/@DragmireXI" aria-label="YouTube">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                </a>
                <a href="https://github.com/GwJZant" aria-label="GitHub">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                </a>
            </div>
        </div>
    </footer>
</body>
</html>